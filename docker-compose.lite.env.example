# Copy to `.env` in this directory — Docker Compose loads it automatically for variable substitution.
# Example: cp docker-compose.lite.env.example .env
#
# After code changes, rebuild the lite app image and restart:
#   yarn docker:lite:rebuild
# (`docker compose ... pull` only updates postgres/temporal/clickhouse — not lite.)

# Dashboard (single-tenant) login password
PASSWORD=password

# Session / crypto — use a long random string in production
SECRET_KEY=change-me-generate-with-openssl-rand-base64-32

WORKSPACE_NAME=Default
AUTH_MODE=single-tenant

# Public URL of the dashboard (used for OAuth redirect_uri construction). Required for multi-tenant OIDC.
# DASHBOARD_URL=http://localhost:3000

# --- Multi-tenant + OIDC (optional) ---
# Set AUTH_MODE=multi-tenant and configure your IdP. Register this callback URL with the IdP:
#   http://localhost:3000/dashboard/oauth2/callback/sso
# Users need a workspace role: use yarn admin onboard-user, or set BOOTSTRAP_ONBOARD_EMAIL for auto-assign on first bootstrap.
#
# AUTH_MODE=multi-tenant
# AUTH_PROVIDER=auth0
# DASHBOARD_URL=http://localhost:3000
# SIGNOUT_URL=/signout
# OPEN_ID_CLIENT_ID=
# OPEN_ID_CLIENT_SECRET=
# OPEN_ID_ISSUER=https://YOUR_TENANT.auth0.com/
# OPEN_ID_AUTHORIZATION_URL=https://YOUR_TENANT.auth0.com/authorize
# OPEN_ID_TOKEN_URL=https://YOUR_TENANT.auth0.com/oauth/token
# OPEN_ID_USER_INFO_URL=https://YOUR_TENANT.auth0.com/userinfo
# OPEN_ID_END_SESSION_ENDPOINT=https://YOUR_TENANT.auth0.com/v2/logout
# OPEN_ID_RETURN_TO_QUERY_PARAM=returnTo
# ENABLE_PKCE=false
# BOOTSTRAP_ONBOARD_EMAIL=you@yourcompany.com

# Local lite stack: `lite` is built from packages/lite/Dockerfile (not pulled).
# Image name for the built lite service (override if you need a registry tag).
# LITE_IMAGE=zora-dittofeed-lite:local
# LITE_APP_VERSION=local

# admin-cli service (optional profile) still uses a published image:
# IMAGE_TAG=v0.23.0

# Optional tuning
# LITE_MEM_LIMIT=824
# LITE_CONTAINER_MEM_LIMIT=1024
# CLICKHOUSE_CONTAINER_MEM_LIMIT=2048
