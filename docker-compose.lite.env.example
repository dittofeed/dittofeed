# Copy to `.env` in this directory — Docker Compose loads it automatically for variable substitution.
# Example: cp docker-compose.lite.env.example .env
#
# After code changes, rebuild the lite app image and restart:
#   yarn docker:lite:rebuild
# (`docker compose ... pull` only updates postgres/temporal/clickhouse — not lite.)

# Dashboard (single-tenant) login password
PASSWORD=password

# Session / crypto — use a long random string in production
SECRET_KEY=change-me-generate-with-openssl-rand-base64-32

WORKSPACE_NAME=Default
AUTH_MODE=single-tenant

# Local lite stack: `lite` is built from packages/lite/Dockerfile (not pulled).
# Image name for the built lite service (override if you need a registry tag).
# LITE_IMAGE=zora-dittofeed-lite:local
# LITE_APP_VERSION=local

# admin-cli service (optional profile) still uses a published image:
# IMAGE_TAG=v0.23.0

# Optional tuning
# LITE_MEM_LIMIT=824
# LITE_CONTAINER_MEM_LIMIT=1024
# CLICKHOUSE_CONTAINER_MEM_LIMIT=2048
